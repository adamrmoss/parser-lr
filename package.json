{
    "name": "parser-lr",
    "version": "0.0.0",
    "description": "Shift-reduce parser library for EBNF grammars",
    "license": "MIT",
    "type": "module",
    "sideEffects": false,
    "main": "./dist/lib/index.js",
    "types": "./dist/lib/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/lib/index.d.ts",
            "import": "./dist/lib/index.js"
        }
    },
    "bin": {
        "parser-lr": "./dist/cli/index.js"
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "npm run build:lib && npm run build:cli",
        "build:lib": "tsc -p tsconfig.lib.json",
        "build:cli": "rollup -c rollup.cli.config.js",
        "clean": "rm -rf dist"
    },
    "dependencies": {},
    "devDependencies": {
        "@rollup/plugin-commonjs": "28.x",
        "@rollup/plugin-node-resolve": "16.x",
        "@rollup/plugin-typescript": "12.x",
        "@types/node": "22.x",
        "commander": "12.x",
        "rollup": "4.x",
        "tslib": "2.x",
        "typescript": "5.x"
    }
}
