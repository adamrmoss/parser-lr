name "optional-absent-repro" ;

tokens
    kw_cls = /CLS/i ;
    kw_with = /WITH/i ;
    ident = /[a-z]+/ ;

skip
    whitespace = /[ \t\r\n]+/ ;

start program_line ;

grammar
    program_line =
        #statement [stmt]:cls_stmt
      ;

    cls_stmt =
        kw_cls [ kw_with ident ]
      ;

transform
    program_line ->
        #statement pass(stmt) ;
